{
  "require": {
    "behat/behat": "^3.12",
    "php-webdriver/webdriver": "^1.11",
    "symfony/yaml": "^6.0"
  },
  "config": {
    "bin-dir": "vendor/bin",
    "audit": {
      "block-insecure": false
    }
  },
  "scripts": {
    "test": "composer androidsingle",
    "androidsingle": "php vendor/bin/behat --config=config/androidsingle.conf.yml",
    "iossingle": "php vendor/bin/behat --config=config/iossingle.conf.yml",
    "androidparallel": "php exec-parallel.php -c config/parallelandroid.conf.yml",
    "iosparallel": "php exec-parallel.php -c config/parallelios.conf.yml"
  },
  "autoload": {
    "classmap": ["lib/"]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
